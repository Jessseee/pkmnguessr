{
	"name": "pokemon-guessr",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "wrangler types && vite build",
		"build:pokemon": "tsx scripts/build-pokemon-json.ts && wrangler kv key put pokemon:all --path .generated/pokemon.json --binding KV --local",
		"deploy": "pnpm build && wrangler deploy",
		"deploy:pokemon": "wrangler kv key put pokemon:all --path .generated/pokemon.json --binding KV --remote",
		"prepare": "svelte-kit sync || echo ''",
		"check": "wrangler types --check && svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write .",
		"preview": "pnpm build && wrangler dev"
	},
	"devDependencies": {
		"@cloudflare/workers-types": "^4.20260615.1",
		"@eslint/compat": "^2.1.0",
		"@eslint/js": "^10.0.1",
		"@sveltejs/adapter-cloudflare": "^7.2.8",
		"@sveltejs/kit": "^2.65.1",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@tailwindcss/forms": "^0.5.11",
		"@tailwindcss/typography": "^0.5.20",
		"@tailwindcss/vite": "^4.3.1",
		"@types/node": "^22.19.21",
		"axios": "^1.18.0",
		"axios-cache-interceptor": "^1.12.0",
		"eslint": "^10.5.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.19.0",
		"globals": "^17.6.0",
		"pokenode-ts": "^1.20.0",
		"prettier": "^3.8.4",
		"prettier-plugin-svelte": "^3.5.2",
		"prettier-plugin-tailwindcss": "^0.7.4",
		"svelte": "^5.56.3",
		"svelte-check": "^4.6.0",
		"tailwindcss": "^4.3.1",
		"tsx": "^4.22.4",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.61.0",
		"vite": "^8.0.16",
		"wrangler": "^4.100.0"
	},
	"dependencies": {
		"@lucide/svelte": "^1.18.0"
	}
}
